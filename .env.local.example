# ConformIA — variables d'environnement
# Copier ce fichier en `.env.local` et remplir avec les valeurs de ton projet
# Supabase (Project Settings → API). `.env.local` est ignoré par git.

# URL du projet Supabase (ex: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clé publique "anon" (safe côté navigateur, protégée par la RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé "service_role" — CONTOURNE la RLS. À n'utiliser QUE côté serveur
# (ingestion extension, moteur de classification). Ne JAMAIS l'exposer au client
# ni la préfixer NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
